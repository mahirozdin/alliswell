# Copy this file to `.env` and adjust the values.
# NEVER commit a real `.env` file — see SECURITY.md.

# ─── Infrastructure (docker compose) ────────────────────────────
MYSQL_ROOT_PASSWORD=alliswell_root
MYSQL_DATABASE=alliswell
MYSQL_USER=alliswell
MYSQL_PASSWORD=alliswell_dev
MYSQL_PORT=3306
REDIS_PORT=6379
API_PORT=3000

# ─── API (apps/api) ─────────────────────────────────────────────
NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306
DATABASE_USER=alliswell
DATABASE_PASSWORD=alliswell_dev
DATABASE_NAME=alliswell
REDIS_URL=redis://127.0.0.1:6379
# Namespaces this deployment's BullMQ keyspace. Change it if more than one
# AllisWell instance shares a Redis — otherwise they consume each other's jobs,
# and since each has its own MySQL the stolen job is silently dropped.
# REDIS_KEY_PREFIX=alliswell
CORS_ORIGIN=*
RATE_LIMIT_MAX=300
# Stricter per-IP limit on /api/v1/auth/* routes (requests per minute):
RATE_LIMIT_AUTH_MAX=10

# ─── Auth (Epic 03 — generate strong random values!) ────────────
# Two DIFFERENT secrets, ≥ 32 chars each: openssl rand -hex 32
# Production refuses to boot with these placeholders (or missing values).
JWT_ACCESS_SECRET=change-me-generate-a-random-secret
JWT_REFRESH_SECRET=change-me-generate-another-random-secret
# Optional token lifetimes (defaults shown):
# AUTH_ACCESS_TTL_SEC=900
# AUTH_REFRESH_TTL_DAYS=30

# ─── Google Calendar (Epic 08 — optional) ───────────────────────
# Create an OAuth client (Web application) in Google Cloud Console and add
# GOOGLE_REDIRECT_URI to its authorized redirect URIs. Without these the
# integration endpoints answer GOOGLE_NOT_CONFIGURED and the app runs fine.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:3000/api/v1/integrations/google/callback
# OAuth tokens are encrypted at rest with AES-256-GCM (ADR-0006).
# 64 hex chars: openssl rand -hex 32 — required in production when Google is configured.
# CALENDAR_TOKEN_KEY=
#
# Where Google POSTs "something changed" notifications (ADR-0007). OPTIONAL:
# Google only pushes to a public https address with a certificate it trusts, so
# leave it unset on localhost/behind NAT — inbound sync then polls instead
# (every CALENDAR_SYNC_SWEEP_SEC) and works exactly the same, just less
# promptly. Your Google Cloud project may also need the domain verified.
# GOOGLE_WEBHOOK_URL=https://your-host.example/api/v1/integrations/google/webhook
# Requested push-channel lifetime. Google caps it and answers with the real
# expiration; we renew a day before THAT, whatever it says.
# CALENDAR_WATCH_TTL_SEC=604800
# How often channels are renewed, dirty accounts retried, and channel-less
# accounts polled.
# CALENDAR_SYNC_SWEEP_SEC=300
