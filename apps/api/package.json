{
  "name": "@alliswell/api",
  "version": "0.1.0",
  "private": true,
  "description": "AllisWell backend API — Fastify, JavaScript only (no TypeScript), MySQL via knex.",
  "license": "AGPL-3.0-only",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run test/unit",
    "test:watch": "vitest test/unit",
    "test:integration": "INTEGRATION=1 vitest run test/integration",
    "db:migrate": "knex migrate:latest",
    "db:rollback": "knex migrate:rollback --all",
    "db:migrate:make": "knex migrate:make"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^10.2.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@socket.io/redis-adapter": "^8.3.0",
    "argon2": "^0.44.0",
    "close-with-grace": "^2.2.0",
    "dotenv": "^17.2.0",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.6.1",
    "knex": "^3.1.0",
    "mysql2": "^3.14.1",
    "socket.io": "^4.8.3",
    "ulid": "^3.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.0",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.3.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.6.2",
    "socket.io-client": "^4.8.3",
    "vitest": "^3.2.4"
  }
}
