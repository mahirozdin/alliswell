<?xml version="1.0" encoding="utf-8"?>
<!-- One row of the widget list (OPH-133): an optional bucket section header, then
     a task line (checkbox glyph, project-color dot, title, time). Bound in
     TasksRemoteViewsFactory. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/aw_row"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="2dp"
    android:paddingBottom="2dp">

    <TextView
        android:id="@+id/aw_section"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingTop="6dp"
        android:paddingBottom="2dp"
        android:textColor="@color/aw_widget_secondary"
        android:textSize="11sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/aw_check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/aw_widget_secondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/aw_dot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textSize="10sp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/aw_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/aw_widget_text"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/aw_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:textColor="@color/aw_widget_secondary"
            android:textSize="12sp" />
    </LinearLayout>
</LinearLayout>
